# TRTC (required)
TRTC_SDK_APP_ID=           # Tencent Cloud TRTC SDKAppID
TRTC_SECRET_KEY=           # TRTC SecretKey for UserSig generation

# Supabase (required for cloud)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# LLM Gateway (OpenAI-compatible endpoint, e.g. OpenClaw, Groq, OpenAI)
LLM_API_KEY=               # Gateway API key / token
LLM_API_URL=               # e.g. http://localhost:18789/v1/chat/completions
LLM_MODEL=                 # e.g. groq:llama-3.3-70b-versatile

# Optional
DESKPILOT_LOG_LEVEL=info   # debug | info | warn | error
DESKPILOT_AUDIT_DIR=~/.deskpilot/
DESKPILOT_MAX_SESSION_MINUTES=30
